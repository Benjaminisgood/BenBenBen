#!/usr/bin/python3
"""A small, dependency-free MCP server for Ben's source-of-truth workspace.

The server intentionally never accepts an arbitrary executable or argv. Read
actions can run from Runtime/manifest.json; write/execute actions and launchd
kicks are reported as approval-required for the native app to review.
"""

from __future__ import annotations

import json
import os
from pathlib import Path
import plistlib
import subprocess
import sys
import time
from typing import Any, Callable, Dict, Iterable, List, Mapping, Optional, Sequence, Tuple


SERVER_NAME = "benbenben-mcp"
SERVER_VERSION = "1.0.0"
TEXT_EXTENSIONS = {
    ".md", ".markdown", ".txt", ".sh", ".zsh", ".bash", ".py",
    ".applescript", ".plist", ".json", ".yaml", ".yml", ".toml",
}
MAX_FILE_BYTES = 4 * 1024 * 1024
MAX_TOOL_OUTPUT = 64 * 1024


class ToolFailure(Exception):
    pass


def runtime_root() -> Path:
    configured = os.environ.get("BENBENBEN_RUNTIME_HOME")
    if configured:
        candidate = Path(configured).expanduser().resolve()
        if (candidate / "manifest.json").is_file():
            return candidate
    return Path(__file__).resolve().parent.parent


def workspace_root() -> Path:
    return Path(os.environ.get("BENBENBEN_WORKSPACE_ROOT", "~/keyoti")).expanduser().resolve()


def workspace_locations() -> List[Tuple[str, Path]]:
    root = workspace_root()
    return [
        ("markdown", root / "mds"),
        ("shell", root / "shs" / "workspace-scripts"),
        ("python", root / "pys"),
        ("applescript", root / "applescripts"),
        ("launchd", root / "launchds"),
    ]


def is_within(path: Path, roots: Iterable[Path]) -> bool:
    resolved = path.expanduser().resolve()
    for root in roots:
        try:
            resolved.relative_to(root.resolve())
            return True
        except ValueError:
            continue
    return False


def iter_source_files() -> Iterable[Tuple[str, Path]]:
    for kind, root in workspace_locations():
        if not root.is_dir():
            continue
        for directory, names, files in os.walk(root):
            names[:] = [name for name in names if not name.startswith(".")]
            for filename in files:
                if filename.startswith("."):
                    continue
                path = Path(directory) / filename
                if path.suffix.lower() not in TEXT_EXTENSIONS:
                    continue
                try:
                    if path.stat().st_size <= MAX_FILE_BYTES:
                        yield kind, path.resolve()
                except OSError:
                    continue


def read_text(path: Path) -> Optional[str]:
    try:
        data = path.read_bytes()
    except OSError:
        return None
    if b"\0" in data:
        return None
    try:
        return data.decode("utf-8")
    except UnicodeDecodeError:
        return None


def require_string(arguments: Mapping[str, Any], key: str) -> str:
    value = arguments.get(key)
    if not isinstance(value, str) or not value.strip():
        raise ToolFailure("{} must be a non-empty string".format(key))
    return value.strip()


def bounded_integer(arguments: Mapping[str, Any], key: str, default: int, low: int, high: int) -> int:
    value = arguments.get(key, default)
    if isinstance(value, bool) or not isinstance(value, int):
        raise ToolFailure("{} must be an integer".format(key))
    return max(low, min(high, value))


def search_knowledge(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    query = require_string(arguments, "query")
    limit = bounded_integer(arguments, "limit", 20, 1, 100)
    terms = [term.casefold() for term in query.split() if term]
    matches: List[Dict[str, Any]] = []

    for kind, path in iter_source_files():
        text = read_text(path)
        if text is None:
            continue
        for line_number, line in enumerate(text.splitlines(), start=1):
            folded = line.casefold()
            if not all(term in folded for term in terms):
                continue
            score = sum(folded.count(term) for term in terms)
            matches.append({
                "path": str(path),
                "line": line_number,
                "kind": kind,
                "snippet": line.strip()[:500],
                "score": score,
            })

    matches.sort(key=lambda item: (-item["score"], item["path"], item["line"]))
    return {"query": query, "count": min(len(matches), limit), "results": matches[:limit]}


def read_document(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    raw_path = require_string(arguments, "path")
    line_start = bounded_integer(arguments, "line_start", 1, 1, 10_000_000)
    line_count = bounded_integer(arguments, "line_count", 200, 1, 2_000)
    path = Path(raw_path).expanduser().resolve()
    roots = [location for _, location in workspace_locations()]
    if not is_within(path, roots):
        raise ToolFailure("path must stay inside ~/keyoti managed roots")
    if not path.is_file():
        raise ToolFailure("document does not exist: {}".format(path))
    text = read_text(path)
    if text is None:
        raise ToolFailure("document is not UTF-8 text")
    lines = text.splitlines()
    selected = lines[line_start - 1: line_start - 1 + line_count]
    return {
        "path": str(path),
        "line_start": line_start,
        "line_end": line_start + max(0, len(selected) - 1),
        "total_lines": len(lines),
        "content": "\n".join(selected),
    }


def recent_activity(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    limit = bounded_integer(arguments, "limit", 30, 1, 200)
    items: List[Dict[str, Any]] = []
    for kind, path in iter_source_files():
        try:
            stat = path.stat()
        except OSError:
            continue
        items.append({
            "path": str(path),
            "kind": kind,
            "modified_at": stat.st_mtime,
            "modified_iso": time.strftime("%Y-%m-%dT%H:%M:%S%z", time.localtime(stat.st_mtime)),
            "bytes": stat.st_size,
        })
    items.sort(key=lambda item: (-item["modified_at"], item["path"]))
    return {"count": min(len(items), limit), "items": items[:limit]}


def load_manifest() -> Dict[str, Any]:
    path = runtime_root() / "manifest.json"
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        raise ToolFailure("Runtime manifest is invalid: {}".format(error)) from error
    if payload.get("schemaVersion") != 1 or not isinstance(payload.get("actions"), list):
        raise ToolFailure("Runtime manifest schema is unsupported")
    return payload


def public_action(action: Mapping[str, Any]) -> Dict[str, Any]:
    return {key: action.get(key) for key in (
        "id", "title", "summary", "risk", "arguments", "cwd", "inputSchema"
    )}


def find_action(action_id: str) -> Mapping[str, Any]:
    for action in load_manifest()["actions"]:
        if action.get("id") == action_id:
            return action
    raise ToolFailure("unknown workflow id: {}".format(action_id))


def action_paths(action: Mapping[str, Any]) -> Tuple[Path, Path]:
    root = runtime_root().resolve()
    raw_executable = action.get("executable")
    if not isinstance(raw_executable, str) or Path(raw_executable).is_absolute():
        raise ToolFailure("workflow executable is not Runtime-relative")
    executable = (root / raw_executable).resolve()
    try:
        executable.relative_to(root)
    except ValueError as error:
        raise ToolFailure("workflow executable escapes Runtime") from error

    replacements = {
        "${BENBENBEN_RUNTIME_HOME}": str(root),
        "${BENBENBEN_PROJECT_HOME}": os.environ.get("BENBENBEN_PROJECT_HOME", "/Users/ben/Desktop/BenBenBen"),
        "${HOME}": str(Path.home()),
    }
    raw_cwd = str(action.get("cwd", ""))
    for marker, value in replacements.items():
        raw_cwd = raw_cwd.replace(marker, value)
    cwd = Path(raw_cwd).expanduser().resolve()
    return executable, cwd


def list_workflows(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    del arguments
    actions = [public_action(action) for action in load_manifest()["actions"]]
    return {"count": len(actions), "workflows": actions}


def workflow_status(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    action = find_action(require_string(arguments, "id"))
    executable, cwd = action_paths(action)
    return {
        **public_action(action),
        "available": executable.is_file() and os.access(str(executable), os.X_OK) and cwd.is_dir(),
        "executable_ready": executable.is_file() and os.access(str(executable), os.X_OK),
        "cwd_ready": cwd.is_dir(),
    }


def run_workflow(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    action = find_action(require_string(arguments, "id"))
    if action.get("risk") != "read":
        return {
            "status": "approval_required",
            "id": action.get("id"),
            "risk": action.get("risk"),
            "message": "Open BenBenBen to review and approve this fixed workflow.",
        }
    executable, cwd = action_paths(action)
    if not executable.is_file() or not cwd.is_dir():
        raise ToolFailure("workflow is unavailable")
    argv = action.get("arguments")
    if not isinstance(argv, list) or not all(isinstance(value, str) for value in argv):
        raise ToolFailure("workflow arguments are invalid")
    environment = os.environ.copy()
    environment["BENBENBEN_RUNTIME_HOME"] = str(runtime_root())
    environment["BENSHELL_HOME"] = str(runtime_root() / "Benshell")
    completed = subprocess.run(
        [str(executable)] + argv,
        cwd=str(cwd),
        env=environment,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=30,
        check=False,
    )
    return {
        "status": "success" if completed.returncode == 0 else "failed",
        "id": action.get("id"),
        "exit_code": completed.returncode,
        "stdout": completed.stdout[-MAX_TOOL_OUTPUT:],
        "stderr": completed.stderr[-MAX_TOOL_OUTPUT:],
    }


def load_jobs() -> List[Dict[str, Any]]:
    launchd_root = workspace_root() / "launchds"
    jobs: List[Dict[str, Any]] = []
    if not launchd_root.is_dir():
        return jobs
    for path in sorted(launchd_root.rglob("*.plist")):
        try:
            with path.open("rb") as handle:
                payload = plistlib.load(handle)
        except (OSError, plistlib.InvalidFileException):
            continue
        label = payload.get("Label")
        if not isinstance(label, str) or not label:
            continue
        jobs.append({
            "id": "job." + path.stem,
            "label": label,
            "path": str(path.resolve()),
            "program": payload.get("Program"),
            "arguments": payload.get("ProgramArguments", []),
            "run_at_load": bool(payload.get("RunAtLoad", False)),
        })
    return jobs


def find_job(job_id: str) -> Dict[str, Any]:
    for job in load_jobs():
        if job["id"] == job_id or job["label"] == job_id:
            return job
    raise ToolFailure("unknown job id: {}".format(job_id))


def list_jobs(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    del arguments
    jobs = load_jobs()
    return {"count": len(jobs), "jobs": jobs}


def job_status(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    job = find_job(require_string(arguments, "id"))
    domain = "gui/{}/{}".format(os.getuid(), job["label"])
    completed = subprocess.run(
        ["/bin/launchctl", "print", domain],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=10,
        check=False,
    )
    return {
        **job,
        "loaded": completed.returncode == 0,
        "launchctl": (completed.stdout or completed.stderr)[-16_384:],
    }


def run_job(arguments: Mapping[str, Any]) -> Dict[str, Any]:
    job = find_job(require_string(arguments, "id"))
    return {
        **job,
        "status": "approval_required",
        "message": "Open BenBenBen to review and approve this launchd kick.",
    }


TOOLS: Dict[str, Tuple[Dict[str, Any], Callable[[Mapping[str, Any]], Dict[str, Any]]]] = {
    "search_knowledge": ({
        "description": "Search Ben's Markdown, shell, Python, AppleScript, and launchd source files.",
        "inputSchema": {"type": "object", "properties": {
            "query": {"type": "string"}, "limit": {"type": "integer", "minimum": 1, "maximum": 100},
        }, "required": ["query"], "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, search_knowledge),
    "read_document": ({
        "description": "Read a bounded line range from a UTF-8 document inside Ben's managed workspace.",
        "inputSchema": {"type": "object", "properties": {
            "path": {"type": "string"}, "line_start": {"type": "integer", "minimum": 1},
            "line_count": {"type": "integer", "minimum": 1, "maximum": 2000},
        }, "required": ["path"], "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, read_document),
    "recent_activity": ({
        "description": "List recently modified managed source files.",
        "inputSchema": {"type": "object", "properties": {
            "limit": {"type": "integer", "minimum": 1, "maximum": 200},
        }, "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, recent_activity),
    "list_workflows": ({
        "description": "List fixed Runtime workflow IDs and their risk classifications.",
        "inputSchema": {"type": "object", "properties": {}, "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, list_workflows),
    "workflow_status": ({
        "description": "Check whether one fixed Runtime workflow is available.",
        "inputSchema": {"type": "object", "properties": {"id": {"type": "string"}},
                        "required": ["id"], "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, workflow_status),
    "run_workflow": ({
        "description": "Run a fixed read-only workflow; mutating workflows are returned for native approval.",
        "inputSchema": {"type": "object", "properties": {"id": {"type": "string"}},
                        "required": ["id"], "additionalProperties": False},
        "annotations": {"readOnlyHint": False, "destructiveHint": True},
    }, run_workflow),
    "list_jobs": ({
        "description": "List launchd jobs defined by plist files in Ben's managed launchds directory.",
        "inputSchema": {"type": "object", "properties": {}, "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, list_jobs),
    "job_status": ({
        "description": "Read launchctl status for a known managed job ID or label.",
        "inputSchema": {"type": "object", "properties": {"id": {"type": "string"}},
                        "required": ["id"], "additionalProperties": False},
        "annotations": {"readOnlyHint": True, "destructiveHint": False},
    }, job_status),
    "run_job": ({
        "description": "Prepare a known managed job for native user approval; never runs launchctl directly.",
        "inputSchema": {"type": "object", "properties": {"id": {"type": "string"}},
                        "required": ["id"], "additionalProperties": False},
        "annotations": {"readOnlyHint": False, "destructiveHint": True},
    }, run_job),
}


def result_payload(payload: Mapping[str, Any], is_error: bool = False) -> Dict[str, Any]:
    return {
        "content": [{"type": "text", "text": json.dumps(payload, ensure_ascii=False, indent=2)}],
        "structuredContent": payload,
        "isError": is_error,
    }


def handle_request(message: Mapping[str, Any]) -> Optional[Dict[str, Any]]:
    request_id = message.get("id")
    method = message.get("method")
    if request_id is None:
        return None

    try:
        if method == "initialize":
            requested = (message.get("params") or {}).get("protocolVersion", "2025-06-18")
            result = {
                "protocolVersion": requested,
                "capabilities": {"tools": {"listChanged": False}},
                "serverInfo": {"name": SERVER_NAME, "version": SERVER_VERSION},
                "instructions": "Read tools are automatic. Workflows and jobs that mutate state require BenBenBen native approval.",
            }
        elif method == "ping":
            result = {}
        elif method == "tools/list":
            result = {"tools": [{"name": name, **metadata} for name, (metadata, _) in TOOLS.items()]}
        elif method == "tools/call":
            params = message.get("params") or {}
            name = params.get("name")
            arguments = params.get("arguments") or {}
            if name not in TOOLS:
                raise ToolFailure("unknown tool: {}".format(name))
            if not isinstance(arguments, dict):
                raise ToolFailure("tool arguments must be an object")
            result = result_payload(TOOLS[name][1](arguments))
        else:
            return {"jsonrpc": "2.0", "id": request_id,
                    "error": {"code": -32601, "message": "Method not found: {}".format(method)}}
        return {"jsonrpc": "2.0", "id": request_id, "result": result}
    except ToolFailure as error:
        return {"jsonrpc": "2.0", "id": request_id,
                "result": result_payload({"error": str(error)}, is_error=True)}
    except Exception as error:  # Keep the stdio server alive and stdout protocol-clean.
        print("{} internal error: {}".format(SERVER_NAME, error), file=sys.stderr)
        return {"jsonrpc": "2.0", "id": request_id,
                "error": {"code": -32603, "message": "Internal error"}}


def main() -> int:
    for raw_line in sys.stdin:
        if not raw_line.strip():
            continue
        try:
            message = json.loads(raw_line)
            if not isinstance(message, dict):
                raise ValueError("message must be an object")
        except (json.JSONDecodeError, ValueError) as error:
            response = {"jsonrpc": "2.0", "id": None,
                        "error": {"code": -32700, "message": "Parse error: {}".format(error)}}
        else:
            response = handle_request(message)
        if response is not None:
            sys.stdout.write(json.dumps(response, ensure_ascii=False, separators=(",", ":")) + "\n")
            sys.stdout.flush()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
