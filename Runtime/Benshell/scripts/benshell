#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"
REPO_HOME="${BENSHELL_HOME:-${SCRIPT_DIR:h}}"

if [[ ! -f "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(command -v -- "${0:t}" 2>/dev/null || true)"
  SCRIPT_DIR="${SCRIPT_PATH:h}"
  REPO_HOME="${BENSHELL_HOME:-${SCRIPT_DIR:h}}"
fi

RUNTIME_CLI="${SCRIPT_DIR:h:h}/bin/benbenben"
if [[ -x "$RUNTIME_CLI" ]]; then
  print -u2 -- "benshell is now provided by BenBenBen; forwarding to benbenben."
  exec "$RUNTIME_CLI" "$@"
fi

source "$SCRIPT_DIR/lib/project-git.zsh"

usage() {
  cat <<'EOF'
Usage: benshell <command>

Commands:
  status            Show local Git branch, remote, divergence, and changes
  git-status        Same as status
  sync [remote]     Pull from and push committed changes to GitHub
  pull [remote]     Pull remote commits with rebase/autostash
  push [remote]     Push committed local history

Environment:
  BENSHELL_HOME       Default: parent of this script directory
  BENSHELL_GIT_REMOTE Optional Git remote override for sync/pull/push
EOF
}

command_name="${1:-status}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  status|git-status|gitstatus) project_git_show_status "$REPO_HOME" "benshell" "${BENSHELL_GIT_REMOTE:-}" "$@" ;;
  sync) project_git_sync "$REPO_HOME" "benshell" "${BENSHELL_GIT_REMOTE:-}" "$@" ;;
  pull) project_git_pull "$REPO_HOME" "benshell" "${BENSHELL_GIT_REMOTE:-}" "$@" ;;
  push) project_git_push "$REPO_HOME" "benshell" "${BENSHELL_GIT_REMOTE:-}" "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
