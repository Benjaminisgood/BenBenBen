#!/usr/bin/env zsh
set -euo pipefail

if [[ -z "${TAPTAP_HOME:-}" || "$TAPTAP_HOME" == "/Users/ben/Desktop/taptap" ]]; then
  TAPTAP_HOME="/Users/ben/Desktop/taptaptap"
fi
TAPTAP_CONDA_ENV="${TAPTAP_CONDA_ENV:-taptap}"
TAPTAP_PYTHON="${TAPTAP_PYTHON:-/Users/ben/miniforge3/envs/$TAPTAP_CONDA_ENV/bin/python}"
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"

if [[ ! -f "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(command -v -- "${0:t}" 2>/dev/null || true)"
  SCRIPT_DIR="${SCRIPT_PATH:h}"
fi

source "$SCRIPT_DIR/lib/project-git.zsh"

say() {
  print -- "$*"
}

die() {
  print -u2 -- "taptap: $*"
  exit 1
}

resolve_conda() {
  if [[ -n "${TAPTAP_CONDA_BIN:-}" && -x "$TAPTAP_CONDA_BIN" ]]; then
    print -- "$TAPTAP_CONDA_BIN"
    return 0
  fi

  if command -v conda >/dev/null 2>&1; then
    command -v conda
    return 0
  fi

  if [[ -x "$HOME/miniforge3/bin/conda" ]]; then
    print -- "$HOME/miniforge3/bin/conda"
    return 0
  fi

  if [[ -x "$HOME/miniconda3/bin/conda" ]]; then
    print -- "$HOME/miniconda3/bin/conda"
    return 0
  fi

  return 1
}

conda_env_exists() {
  local conda_bin="$1"
  "$conda_bin" env list | awk '{print $1}' | grep -qx "$TAPTAP_CONDA_ENV"
}

preflight() {
  [[ -d "$TAPTAP_HOME" ]] || die "$TAPTAP_HOME does not exist"
  [[ -x "$TAPTAP_PYTHON" ]] || die "$TAPTAP_PYTHON not found. Run: taptap setup"
}

setup_all() {
  [[ -d "$TAPTAP_HOME" ]] || die "$TAPTAP_HOME does not exist"

  local conda_bin
  conda_bin="$(resolve_conda)" || die "conda not found. Install Miniforge/Miniconda, or set TAPTAP_CONDA_BIN"

  if conda_env_exists "$conda_bin"; then
    say "conda env ok: $TAPTAP_CONDA_ENV"
  else
    say "creating conda env: $TAPTAP_CONDA_ENV"
    if [[ -f "$TAPTAP_HOME/environment.yml" ]]; then
      "$conda_bin" env create -n "$TAPTAP_CONDA_ENV" -f "$TAPTAP_HOME/environment.yml"
    else
      "$conda_bin" create -y -n "$TAPTAP_CONDA_ENV" python=3.12
    fi
  fi

  [[ -x "$TAPTAP_PYTHON" ]] || die "$TAPTAP_PYTHON not found after setup"

  say "installing editable taptap package"
  (cd "$TAPTAP_HOME" && "$TAPTAP_PYTHON" -m pip install -e ".[dev]")
  say "setup complete"
}

run_cli() {
  preflight
  exec "$TAPTAP_PYTHON" -m taptap "$@"
}

status_all() {
  preflight

  say "python:"
  say "  $TAPTAP_PYTHON"

  say ""
  say "package:"
  (
    cd "$TAPTAP_HOME"
    "$TAPTAP_PYTHON" - <<'PY'
import sys

try:
    import taptap
except Exception as exc:
    print(f"  import failed: {exc}")
else:
    print(f"  taptap {taptap.__version__}")
    print(f"  executable: {sys.executable}")
PY
  ) || true

  say ""
  project_git_show_status "$TAPTAP_HOME" "taptap" "${TAPTAP_GIT_REMOTE:-}" "$@"
}

usage() {
  cat <<'EOF'
Usage: taptap <command>

Controller commands:
  setup             Create or refresh the taptap conda env and editable install
  status            Show Python package details plus Git status/divergence
  git-status        Show local Git branch, remote, divergence, and changes
  sync [remote]     Pull from and push committed changes to GitHub
  pull [remote]     Pull remote commits with rebase/autostash
  push [remote]     Push committed local history
  cli ...           Run the underlying taptap CLI with python -m taptap

Other commands are passed through to the underlying taptap CLI, so
`taptap init_mini_tap ...` and `taptap wyx_convert file ...` keep working
from the current working directory.

Environment:
  TAPTAP_HOME        Default: /Users/ben/Desktop/taptaptap
  TAPTAP_CONDA_ENV   Default: taptap
  TAPTAP_PYTHON      Default: /Users/ben/miniforge3/envs/taptap/bin/python
  TAPTAP_GIT_REMOTE  Optional Git remote override for sync/pull/push
EOF
}

command_name="${1:-help}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  setup) setup_all "$@" ;;
  status) status_all "$@" ;;
  sync) project_git_sync "$TAPTAP_HOME" "taptap" "${TAPTAP_GIT_REMOTE:-}" "$@" ;;
  pull) project_git_pull "$TAPTAP_HOME" "taptap" "${TAPTAP_GIT_REMOTE:-}" "$@" ;;
  push) project_git_push "$TAPTAP_HOME" "taptap" "${TAPTAP_GIT_REMOTE:-}" "$@" ;;
  git-status|gitstatus) project_git_show_status "$TAPTAP_HOME" "taptap" "${TAPTAP_GIT_REMOTE:-}" "$@" ;;
  cli) run_cli "$@" ;;
  help) usage ;;
  -h|--help) run_cli "$command_name" "$@" ;;
  *) run_cli "$command_name" "$@" ;;
esac
