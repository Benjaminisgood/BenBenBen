#!/usr/bin/env zsh
set -euo pipefail

BENBENBEN_PROJECT_HOME="${BENBENBEN_PROJECT_HOME:-/Users/ben/Desktop/BenBenBen}"
BENBENBEN_APP_NAME="${BENBENBEN_APP_NAME:-BenBenBen}"
BENBENBEN_GIT_REMOTE="${BENBENBEN_GIT_REMOTE:-origin}"
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"

source "$SCRIPT_DIR/lib/project-git.zsh"

say() {
  print -- "$*"
}

die() {
  print -u2 -- "benbenben: $*"
  exit 1
}

preflight() {
  [[ -d "$BENBENBEN_PROJECT_HOME" ]] || die "$BENBENBEN_PROJECT_HOME does not exist"
  [[ -f "$BENBENBEN_PROJECT_HOME/Package.swift" ]] || die "Package.swift not found"
}

require_run_script() {
  preflight
  [[ -x "$BENBENBEN_PROJECT_HOME/Scripts/build_and_run.sh" ]] || die "Scripts/build_and_run.sh not found or not executable"
}

stop_app() {
  local pid
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    pkill -TERM -P "$pid" >/dev/null 2>&1 || true
    kill -TERM "$pid" >/dev/null 2>&1 || true
  done < <(pgrep -x "$BENBENBEN_APP_NAME" || true)
  say "stopped $BENBENBEN_APP_NAME"
}

status_all() {
  preflight
  say "app:"
  if pgrep -x "$BENBENBEN_APP_NAME" >/dev/null 2>&1; then
    say "  $BENBENBEN_APP_NAME: running"
  else
    say "  $BENBENBEN_APP_NAME: stopped"
  fi
  say ""
  project_git_show_status "$BENBENBEN_PROJECT_HOME" "BenBenBen" "$BENBENBEN_GIT_REMOTE" "$@"
}

build_product() {
  preflight
  cd "$BENBENBEN_PROJECT_HOME"
  swift build --product "$BENBENBEN_APP_NAME" "$@"
}

run_script() {
  require_run_script
  cd "$BENBENBEN_PROJECT_HOME"
  ./Scripts/build_and_run.sh "$@"
}

test_logic() {
  preflight
  cd "$BENBENBEN_PROJECT_HOME"
  swift test "$@"
}

package_app() {
  preflight
  [[ -x "$BENBENBEN_PROJECT_HOME/Scripts/package-app.sh" ]] || die "Scripts/package-app.sh not found or not executable"
  cd "$BENBENBEN_PROJECT_HOME"
  ./Scripts/package-app.sh "$@"
}

usage() {
  cat <<'EOF'
Usage: benbenben <command>

App commands:
  status            Show app process state plus Git status/divergence
  build             Build the SwiftPM BenBenBen product
  run               Build, bundle, sign, install Runtime, and launch the app
  verify            Build, launch, and verify the BenBenBen process starts
  stop              Stop the running BenBenBen process
  test              Run the project logic smoke tests
  logs              Launch and stream process logs
  telemetry         Launch and stream app subsystem logs
  debug             Build and open the executable in lldb
  package           Build the release app package
  sync [remote]     Explicitly pull and push committed Git history
  pull [remote]     Explicitly pull with rebase/autostash
  push [remote]     Explicitly push committed Git history
  git-status        Show local Git status/divergence

Environment:
  BENBENBEN_PROJECT_HOME  Default: /Users/ben/Desktop/BenBenBen
  BENBENBEN_APP_NAME      Default: BenBenBen
  BENBENBEN_GIT_REMOTE    Default: origin

Nothing in Runtime startup automatically runs sync, pull, push, Brewfile, or macOS defaults.
EOF
}

command_name="${1:-help}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  status) status_all "$@" ;;
  build) build_product "$@" ;;
  run|start) run_script run "$@" ;;
  verify) run_script verify "$@" ;;
  stop) stop_app "$@" ;;
  restart) stop_app; run_script run "$@" ;;
  test) test_logic "$@" ;;
  logs) run_script --logs "$@" ;;
  telemetry) run_script --telemetry "$@" ;;
  debug) run_script --debug "$@" ;;
  package) package_app "$@" ;;
  sync) project_git_sync "$BENBENBEN_PROJECT_HOME" "BenBenBen" "$BENBENBEN_GIT_REMOTE" "$@" ;;
  pull) project_git_pull "$BENBENBEN_PROJECT_HOME" "BenBenBen" "$BENBENBEN_GIT_REMOTE" "$@" ;;
  push) project_git_push "$BENBENBEN_PROJECT_HOME" "BenBenBen" "$BENBENBEN_GIT_REMOTE" "$@" ;;
  git-status|gitstatus) project_git_show_status "$BENBENBEN_PROJECT_HOME" "BenBenBen" "$BENBENBEN_GIT_REMOTE" "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
