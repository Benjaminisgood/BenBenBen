#!/usr/bin/env zsh
set -euo pipefail

PAPIS_HOME="${PAPIS_HOME:-/Users/ben/Desktop/papis}"
PAPIS_BIN="${PAPIS_BIN:-$PAPIS_HOME/.venv/bin/papis}"
RUN_DIR="${PAPIS_RUN_DIR:-/tmp/papis-run}"
SESSION="${PAPIS_SESSION:-papis}"
SERVE_HOST="${PAPIS_SERVE_HOST:-127.0.0.1}"
SERVE_PORT="${PAPIS_SERVE_PORT:-8888}"
SERVE_URL="${PAPIS_SERVE_URL:-http://$SERVE_HOST:$SERVE_PORT/}"
PAPIS_GIT_REMOTE="${PAPIS_GIT_REMOTE:-origin}"
PORTS=("$SERVE_PORT")
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"

if [[ ! -f "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(command -v -- "${0:t}" 2>/dev/null || true)"
  SCRIPT_DIR="${SCRIPT_PATH:h}"
fi

source "$SCRIPT_DIR/lib/project-git.zsh"

say() {
  print -- "$*"
}

die() {
  print -u2 -- "papis: $*"
  exit 1
}

screen_has_session() {
  local session="$1"
  local listing
  listing="$(screen -ls 2>/dev/null || true)"
  grep -q "[.]${session}[[:space:]]" <<< "$listing"
}

quit_session() {
  local session="$1"
  screen -S "$session" -X quit >/dev/null 2>&1 || true
}

kill_port_listeners() {
  local port pids

  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      say "killing listener(s) on port $port: ${(j: :)${(f)pids}}"
      print -r -- "$pids" | xargs kill 2>/dev/null || true
    fi
  done
}

ports_are_free() {
  local port pids busy=0

  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      print -u2 -- "port $port is busy: ${(j: :)${(f)pids}}"
      busy=1
    fi
  done

  return "$busy"
}

preflight() {
  [[ -d "$PAPIS_HOME" ]] || die "$PAPIS_HOME does not exist"
  [[ -x "$PAPIS_BIN" ]] || die "$PAPIS_BIN not found. Run: papis setup"
}

setup_all() {
  [[ -d "$PAPIS_HOME" ]] || die "$PAPIS_HOME does not exist"

  if [[ -x "$PAPIS_BIN" ]]; then
    say "python env ok: $PAPIS_BIN"
    return 0
  fi

  local python_bin="${PAPIS_BOOTSTRAP_PYTHON:-}"
  if [[ -z "$python_bin" ]]; then
    if command -v python3.11 >/dev/null 2>&1; then
      python_bin="$(command -v python3.11)"
    elif command -v python3 >/dev/null 2>&1; then
      python_bin="$(command -v python3)"
    else
      die "python3.11 or python3 not found"
    fi
  fi

  say "creating Papis venv with $python_bin"
  (cd "$PAPIS_HOME" && "$python_bin" -m venv .venv)
  (cd "$PAPIS_HOME" && .venv/bin/python -m pip install --upgrade pip setuptools wheel)
  (cd "$PAPIS_HOME" && .venv/bin/python -m pip install -e .)
  say "setup complete"
}

run_serve_foreground() {
  mkdir -p "$RUN_DIR"
  cd "$PAPIS_HOME"
  exec "$PAPIS_BIN" serve --address "$SERVE_HOST" --port "$SERVE_PORT" "$@"
}

run_cli() {
  preflight
  cd "$PAPIS_HOME"
  exec "$PAPIS_BIN" "$@"
}

wait_for_url() {
  local url="$1"
  local -i attempts="${2:-80}"
  local -i i

  for (( i = 1; i <= attempts; i++ )); do
    curl -fsS --max-time 1 "$url" >/dev/null 2>&1 && return 0
    sleep 0.5
  done

  return 1
}

start_all() {
  preflight
  mkdir -p "$RUN_DIR"
  [[ -f "$SCRIPT_PATH" ]] || die "cannot resolve script path"

  if screen_has_session "$SESSION"; then
    say "$SESSION is already running"
    status_all
    return 0
  fi

  ports_are_free || die "ports are busy. Run: papis stop --ports"

  : > "$RUN_DIR/serve.log"
  screen -dmS "$SESSION" /bin/zsh "$SCRIPT_PATH" __serve "$@"
  say "started screen session: $SESSION"

  if wait_for_url "$SERVE_URL" 80; then
    say "serve ok: $SERVE_URL"
    if [[ "${PAPIS_SERVE_OPEN:-1}" == "1" ]] && command -v open >/dev/null 2>&1; then
      open "$SERVE_URL" >/dev/null 2>&1 || true
    fi
  else
    say "serve is still starting; check: papis logs"
  fi
}

stop_all() {
  local kill_ports=0

  if [[ "${1:-}" == "--ports" || "${1:-}" == "--force" ]]; then
    kill_ports=1
  elif [[ -n "${1:-}" ]]; then
    die "unknown stop option: $1"
  fi

  quit_session "$SESSION"

  if (( kill_ports )); then
    kill_port_listeners
  fi

  say "stopped Papis"
}

status_all() {
  say "session:"
  if screen_has_session "$SESSION"; then
    say "  $SESSION: running"
  else
    say "  $SESSION: stopped"
  fi

  say ""
  say "ports:"
  local port pids
  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      say "  $port: ${(j: :)${(f)pids}}"
    else
      say "  $port: free"
    fi
  done

  say ""
  if curl -fsS --max-time 2 "$SERVE_URL" >/dev/null 2>&1; then
    say "serve: $SERVE_URL"
  else
    say "serve: unavailable ($SERVE_URL)"
  fi
}

logs_all() {
  local follow=0
  local arg

  for arg in "$@"; do
    case "$arg" in
      -f|--follow) follow=1 ;;
      *) die "unknown logs option: $arg" ;;
    esac
  done

  local -a tail_args
  tail_args=(-n 160)
  (( follow )) && tail_args=(-n 160 -f)
  tail "${tail_args[@]}" "$RUN_DIR/serve.log"
}

open_serve() {
  command -v open >/dev/null 2>&1 || die "macOS open command not found"
  open "$SERVE_URL"
}

usage() {
  cat <<'EOF'
Usage: papis <command>

Controller commands:
  setup             Create the local Papis venv if missing
  start             Start `papis serve` in a screen session
  stop [--ports]    Stop the screen session; --ports also kills the serve port
  restart           Stop with --ports, then start
  status            Show session, port, and serve health
  logs [-f]         Show or follow the serve log
  open              Open the local serve URL
  sync [remote]     Pull from and push committed changes to GitHub
  pull [remote]     Pull remote commits with rebase/autostash
  push [remote]     Push committed local history
  git-status        Show local Git branch, remote, divergence, and changes
  cli ...           Run the underlying papis CLI from the project venv

Other commands are passed through to the underlying papis CLI, so `papis list`,
`papis doctor`, and `papis serve` keep working as foreground commands.

Environment:
  PAPIS_HOME        Default: /Users/ben/Desktop/papis
  PAPIS_RUN_DIR     Default: /tmp/papis-run
  PAPIS_SERVE_URL   Default: http://127.0.0.1:8888/
  PAPIS_GIT_REMOTE  Git remote for sync/pull/push. Default: origin
EOF
}

command_name="${1:-help}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  __serve)
    mkdir -p "$RUN_DIR"
    exec >> "$RUN_DIR/serve.log" 2>&1
    run_serve_foreground "$@"
    ;;
  setup) setup_all "$@" ;;
  start) start_all "$@" ;;
  stop) stop_all "$@" ;;
  restart) stop_all --ports; start_all "$@" ;;
  status) status_all "$@" ;;
  logs) logs_all "$@" ;;
  open) open_serve "$@" ;;
  sync) project_git_sync "$PAPIS_HOME" "papis" "$PAPIS_GIT_REMOTE" "$@" ;;
  pull) project_git_pull "$PAPIS_HOME" "papis" "$PAPIS_GIT_REMOTE" "$@" ;;
  push) project_git_push "$PAPIS_HOME" "papis" "$PAPIS_GIT_REMOTE" "$@" ;;
  git-status|gitstatus) project_git_show_status "$PAPIS_HOME" "papis" "$PAPIS_GIT_REMOTE" "$@" ;;
  cli) run_cli "$@" ;;
  help|-h|--help) usage ;;
  *) run_cli "$command_name" "$@" ;;
esac
