#!/usr/bin/env zsh
set -euo pipefail

NANOBOT_HOME="${NANOBOT_HOME:-/Users/ben/Desktop/nanobot}"
NANOBOT_BIN="${NANOBOT_BIN:-$NANOBOT_HOME/.venv/bin/nanobot}"
FRONTEND_HOME="${NANOBOT_FRONTEND_HOME:-$NANOBOT_HOME/webui}"
RUN_DIR="${NANOBOT_RUN_DIR:-/tmp/nanobot-run}"
GATEWAY_SESSION="${NANOBOT_GATEWAY_SESSION:-nanobot-gateway}"
FRONTEND_SESSION="${NANOBOT_FRONTEND_SESSION:-nanobot-frontend}"
OPENAI_API_SESSION="${NANOBOT_OPENAI_API_SESSION:-nanobot-api}"
API_URL="${NANOBOT_API_URL:-http://127.0.0.1:8765}"
FRONTEND_URL="${NANOBOT_FRONTEND_URL:-http://127.0.0.1:5173/}"
HEALTH_URL="${NANOBOT_GATEWAY_HEALTH_URL:-http://127.0.0.1:18790/health}"
OPENAI_API_HOST="${NANOBOT_OPENAI_API_HOST:-127.0.0.1}"
OPENAI_API_PORT="${NANOBOT_OPENAI_API_PORT:-1234}"
OPENAI_API_URL="${NANOBOT_OPENAI_API_URL:-http://$OPENAI_API_HOST:$OPENAI_API_PORT}"
PORTS=("$OPENAI_API_PORT" 8765 18790 5173 5174)
SCRIPT_PATH="${0:A}"
SCRIPT_DIR="${SCRIPT_PATH:h}"

if [[ ! -f "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(command -v -- "${0:t}" 2>/dev/null || true)"
  SCRIPT_DIR="${SCRIPT_PATH:h}"
fi

source "$SCRIPT_DIR/lib/project-git.zsh"

say() {
  print -- "$*"
}

die() {
  print -u2 -- "nanobot: $*"
  exit 1
}

resolve_node_runner() {
  if [[ -n "${NANOBOT_NPM_BIN:-}" && -x "$NANOBOT_NPM_BIN" ]]; then
    print -- "npm:$NANOBOT_NPM_BIN"
    return 0
  fi

  if [[ -x "$HOME/.local/nanobot-node/bin/npm" ]]; then
    print -- "npm:$HOME/.local/nanobot-node/bin/npm"
    return 0
  fi

  if command -v npm >/dev/null 2>&1; then
    print -- "npm:$(command -v npm)"
    return 0
  fi

  if command -v bun >/dev/null 2>&1; then
    print -- "bun:$(command -v bun)"
    return 0
  fi

  return 1
}

screen_has_session() {
  local session="$1"
  local listing
  listing="$(screen -ls 2>/dev/null || true)"
  grep -q "[.]${session}[[:space:]]" <<< "$listing"
}

quit_session() {
  local session="$1"
  screen -S "$session" -X quit >/dev/null 2>&1 || true
}

kill_port_listeners() {
  local port pids

  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      say "killing listener(s) on port $port: ${(j: :)${(f)pids}}"
      print -r -- "$pids" | xargs kill 2>/dev/null || true
    fi
  done
}

ports_are_free() {
  local port pids busy=0

  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      print -u2 -- "port $port is busy: ${(j: :)${(f)pids}}"
      busy=1
    fi
  done

  return "$busy"
}

preflight() {
  [[ -d "$NANOBOT_HOME" ]] || die "$NANOBOT_HOME does not exist"
  [[ -d "$FRONTEND_HOME" ]] || die "$FRONTEND_HOME does not exist"
  [[ -x "$NANOBOT_BIN" ]] || die "$NANOBOT_BIN not found. Run: nanobot setup"
  resolve_node_runner >/dev/null || die "npm or bun not found. Install Node.js, or set NANOBOT_NPM_BIN"
  [[ -d "$FRONTEND_HOME/node_modules" ]] || die "$FRONTEND_HOME/node_modules not found. Run: nanobot setup"
}

setup_python() {
  if [[ -x "$NANOBOT_BIN" ]]; then
    say "python env ok: $NANOBOT_BIN"
    return 0
  fi

  local python_bin="${NANOBOT_PYTHON:-}"
  if [[ -z "$python_bin" ]]; then
    if command -v python3.12 >/dev/null 2>&1; then
      python_bin="$(command -v python3.12)"
    elif command -v python3 >/dev/null 2>&1; then
      python_bin="$(command -v python3)"
    else
      die "python3.12 or python3 not found"
    fi
  fi

  say "creating nanobot venv with $python_bin"
  (cd "$NANOBOT_HOME" && "$python_bin" -m venv .venv)
  (cd "$NANOBOT_HOME" && .venv/bin/pip install --upgrade pip setuptools wheel)
  (cd "$NANOBOT_HOME" && .venv/bin/pip install -e .)
}

setup_frontend() {
  if [[ -d "$FRONTEND_HOME/node_modules" ]]; then
    say "frontend deps ok: $FRONTEND_HOME/node_modules"
    return 0
  fi

  local resolved kind bin
  resolved="$(resolve_node_runner)" || die "npm or bun not found. Install Node.js, or set NANOBOT_NPM_BIN"
  kind="${resolved%%:*}"
  bin="${resolved#*:}"

  say "installing frontend deps with $bin"
  if [[ "$kind" == "bun" ]]; then
    (cd "$FRONTEND_HOME" && "$bin" install)
  else
    "$bin" --prefix "$FRONTEND_HOME" install
  fi
}

setup_all() {
  [[ -d "$NANOBOT_HOME" ]] || die "$NANOBOT_HOME does not exist"
  [[ -d "$FRONTEND_HOME" ]] || die "$FRONTEND_HOME does not exist"

  setup_python
  setup_frontend
  say "setup complete"
}

run_gateway_foreground() {
  mkdir -p "$RUN_DIR"
  cd "$NANOBOT_HOME"
  exec "$NANOBOT_BIN" gateway >> "$RUN_DIR/gateway.log" 2>&1
}

run_openai_api_foreground() {
  mkdir -p "$RUN_DIR"
  cd "$NANOBOT_HOME"
  exec "$NANOBOT_BIN" serve --host "$OPENAI_API_HOST" --port "$OPENAI_API_PORT" >> "$RUN_DIR/api.log" 2>&1
}

run_frontend_foreground() {
  mkdir -p "$RUN_DIR"
  cd "$NANOBOT_HOME"

  local resolved kind bin
  resolved="$(resolve_node_runner)" || {
    print -u2 -- "npm or bun not found"
    exit 1
  }
  kind="${resolved%%:*}"
  bin="${resolved#*:}"

  export NANOBOT_API_URL="$API_URL"

  if [[ "$kind" == "bun" ]]; then
    cd "$FRONTEND_HOME"
    exec "$bin" run dev >> "$RUN_DIR/frontend.log" 2>&1
  fi

  exec "$bin" --prefix "$FRONTEND_HOME" run dev >> "$RUN_DIR/frontend.log" 2>&1
}

wait_for_url() {
  local url="$1"
  local method="${2:-GET}"
  local -i attempts="${3:-40}"
  local -i i

  for (( i = 1; i <= attempts; i++ )); do
    if [[ "$method" == "HEAD" ]]; then
      curl -fsSI --max-time 1 "$url" >/dev/null 2>&1 && return 0
    else
      curl -fsS --max-time 1 "$url" >/dev/null 2>&1 && return 0
    fi
    sleep 0.5
  done

  return 1
}

start_all() {
  preflight
  mkdir -p "$RUN_DIR"

  quit_session "$GATEWAY_SESSION"
  quit_session "$FRONTEND_SESSION"
  quit_session "$OPENAI_API_SESSION"
  sleep 0.2

  ports_are_free || die "ports are busy. Run: nanobot stop --ports"

  : > "$RUN_DIR/api.log"
  : > "$RUN_DIR/gateway.log"
  : > "$RUN_DIR/frontend.log"

  [[ -f "$SCRIPT_PATH" ]] || die "cannot resolve script path"

  screen -dmS "$OPENAI_API_SESSION" /bin/zsh "$SCRIPT_PATH" __api
  screen -dmS "$GATEWAY_SESSION" /bin/zsh "$SCRIPT_PATH" __gateway
  screen -dmS "$FRONTEND_SESSION" /bin/zsh "$SCRIPT_PATH" __frontend

  say "started screen sessions: $OPENAI_API_SESSION, $GATEWAY_SESSION, $FRONTEND_SESSION"

  if wait_for_url "$OPENAI_API_URL/health" GET 40; then
    say "openai api ok: $OPENAI_API_URL/v1/chat/completions"
  else
    say "openai api is still starting; check: nanobot logs api"
  fi

  if wait_for_url "$HEALTH_URL" GET 40; then
    say "gateway ok: $HEALTH_URL"
  else
    say "gateway is still starting; check: nanobot logs gateway"
  fi

  if wait_for_url "$FRONTEND_URL" HEAD 40; then
    say "frontend ok: $FRONTEND_URL"
    if [[ "${NANOBOT_FRONTEND_OPEN:-1}" == "1" ]] && command -v open >/dev/null 2>&1; then
      open "$FRONTEND_URL" >/dev/null 2>&1 || true
    fi
  else
    say "frontend is still starting; check: nanobot logs frontend"
  fi
}

stop_all() {
  local kill_ports=0

  if [[ "${1:-}" == "--ports" || "${1:-}" == "--force" ]]; then
    kill_ports=1
  fi

  quit_session "$FRONTEND_SESSION"
  quit_session "$GATEWAY_SESSION"
  quit_session "$OPENAI_API_SESSION"

  if (( kill_ports )); then
    kill_port_listeners
  fi

  say "stopped screen sessions"
}

status_all() {
  say "sessions:"
  if screen_has_session "$OPENAI_API_SESSION"; then
    say "  $OPENAI_API_SESSION: running"
  else
    say "  $OPENAI_API_SESSION: stopped"
  fi

  if screen_has_session "$GATEWAY_SESSION"; then
    say "  $GATEWAY_SESSION: running"
  else
    say "  $GATEWAY_SESSION: stopped"
  fi

  if screen_has_session "$FRONTEND_SESSION"; then
    say "  $FRONTEND_SESSION: running"
  else
    say "  $FRONTEND_SESSION: stopped"
  fi

  say ""
  say "ports:"
  local port pids
  for port in $PORTS; do
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      say "  $port: ${(j: :)${(f)pids}}"
    else
      say "  $port: free"
    fi
  done

  say ""
  if curl -fsS --max-time 2 "$OPENAI_API_URL/health" >/dev/null 2>&1; then
    say "openai api: ok ($OPENAI_API_URL/v1/chat/completions)"
  else
    say "openai api: unavailable ($OPENAI_API_URL/v1/chat/completions)"
  fi

  if curl -fsS --max-time 2 "$HEALTH_URL" >/dev/null 2>&1; then
    say "gateway health: ok"
  else
    say "gateway health: unavailable"
  fi

  if curl -fsSI --max-time 2 "$FRONTEND_URL" >/dev/null 2>&1; then
    say "frontend: $FRONTEND_URL"
  else
    say "frontend: unavailable"
  fi
}

logs_all() {
  local follow=0
  local target="all"
  local arg

  for arg in "$@"; do
    case "$arg" in
      -f|--follow) follow=1 ;;
      api|gateway|frontend|all) target="$arg" ;;
      *) die "unknown logs target: $arg" ;;
    esac
  done

  local -a tail_args
  tail_args=(-n 120)
  (( follow )) && tail_args=(-n 120 -f)

  case "$target" in
    api) tail "${tail_args[@]}" "$RUN_DIR/api.log" ;;
    gateway) tail "${tail_args[@]}" "$RUN_DIR/gateway.log" ;;
    frontend) tail "${tail_args[@]}" "$RUN_DIR/frontend.log" ;;
    all) tail "${tail_args[@]}" "$RUN_DIR/api.log" "$RUN_DIR/gateway.log" "$RUN_DIR/frontend.log" ;;
  esac
}

open_frontend() {
  command -v open >/dev/null 2>&1 || die "macOS open command not found"
  open "$FRONTEND_URL"
}

run_cli() {
  [[ -d "$NANOBOT_HOME" ]] || die "$NANOBOT_HOME does not exist"
  [[ -x "$NANOBOT_BIN" ]] || die "$NANOBOT_BIN not found. Run: nanobot setup"
  cd "$NANOBOT_HOME"
  exec "$NANOBOT_BIN" "$@"
}

usage() {
  cat <<'EOF'
Usage: nanobot <command>

Commands:
  setup             Install nanobot Python env and frontend dependencies if missing
  start             Start API, gateway, and frontend in screen sessions
  stop [--ports]    Stop screen sessions; --ports also kills listeners on nanobot ports
  restart           Stop with --ports, then start
  status            Show sessions, ports, and health
  logs [target]     Show logs; target is api, gateway, frontend, or all
  logs -f [target]  Follow logs
  open              Open the frontend URL
  sync [remote]     Pull from and push committed changes to GitHub
  pull [remote]     Pull remote commits with rebase/autostash
  push [remote]     Push committed local history
  git-status        Show local Git branch, remote, divergence, and changes
  cli ...           Run the underlying nanobot CLI from the project venv

Environment:
  NANOBOT_HOME      Default: /Users/ben/Desktop/nanobot
  NANOBOT_RUN_DIR   Default: /tmp/nanobot-run
  NANOBOT_API_URL   Default: http://127.0.0.1:8765
  NANOBOT_FRONTEND_URL Default: http://127.0.0.1:5173/
  NANOBOT_OPENAI_API_URL Default: http://127.0.0.1:1234
  NANOBOT_GIT_REMOTE Optional Git remote override for sync/pull/push
EOF
}

command_name="${1:-help}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  __api)
    mkdir -p "$RUN_DIR"
    exec >> "$RUN_DIR/api.log" 2>&1
    run_openai_api_foreground "$@"
    ;;
  __gateway)
    mkdir -p "$RUN_DIR"
    exec >> "$RUN_DIR/gateway.log" 2>&1
    run_gateway_foreground "$@"
    ;;
  __frontend)
    mkdir -p "$RUN_DIR"
    exec >> "$RUN_DIR/frontend.log" 2>&1
    run_frontend_foreground "$@"
    ;;
  setup) setup_all "$@" ;;
  start) start_all "$@" ;;
  stop) stop_all "$@" ;;
  restart) stop_all --ports; start_all "$@" ;;
  status) status_all "$@" ;;
  logs) logs_all "$@" ;;
  open) open_frontend "$@" ;;
  sync) project_git_sync "$NANOBOT_HOME" "nanobot" "${NANOBOT_GIT_REMOTE:-}" "$@" ;;
  pull) project_git_pull "$NANOBOT_HOME" "nanobot" "${NANOBOT_GIT_REMOTE:-}" "$@" ;;
  push) project_git_push "$NANOBOT_HOME" "nanobot" "${NANOBOT_GIT_REMOTE:-}" "$@" ;;
  git-status|gitstatus) project_git_show_status "$NANOBOT_HOME" "nanobot" "${NANOBOT_GIT_REMOTE:-}" "$@" ;;
  cli) run_cli "$@" ;;
  help|-h|--help) usage ;;
  *) run_cli "$command_name" "$@" ;;
esac
